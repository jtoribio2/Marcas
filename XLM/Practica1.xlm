ELEMENTOS:
- cotxes (arrel)
- nous
- usats
- cotxe

ATRIBUTS:
- marca
- model
- color

CONTENIDO:
- matrícula o texto dentro de <cotxe>

<?xml version="1.0" encoding="UTF-8"?>
<cotxes>
  <cotxe marca="seat" model="ibiza" color="blau" usat="false">T-8976-AW</cotxe>
  <cotxe marca="opel" model="corsa" color="blanc" usat="false">Sense Matricular</cotxe>
  <cotxe marca="renault" model="megane" color="gris" usat="true">1111BCC</cotxe>
  <cotxe marca="opel" model="corsa" color="blanc" usat="true">9344BDF</cotxe>
</cotxes>

<?xml version="1.0" encoding="UTF-8"?>
<cotxes>
  <nous>
    <cotxe>
      <marca>seat</marca>
      <model>ibiza</model>
      <color>blau</color>
      <matricula>T-8976-AW</matricula>
    </cotxe>
    <cotxe>
      <marca>opel</marca>
      <model>corsa</model>
      <color>blanc</color>
      <matricula>Sense Matricular</matricula>
    </cotxe>
  </nous>
  <usats>
    <cotxe>
      <marca>renault</marca>
      <model>megane</model>
      <color>gris</color>
      <matricula>1111BCC</matricula>
    </cotxe>
    <cotxe>
      <marca>opel</marca>
      <model>corsa</model>
      <color>blanc</color>
      <matricula>9344BDF</matricula>
    </cotxe>
  </usats>
</cotxes>

<?xml version="1.0" encoding="UTF-8"?>
<memos>
  <memo lang="cat">
    <to>Joan</to>
    <from>Carme</from>
    <cc></cc>
    <subject>Capitol 1: XML Interchange Format</subject>
  </memo>

  <memo>
    <to>Carme</to>
    <subject>Capítol 2: JSON Interchange Format</subject>
  </memo>
</memos>

